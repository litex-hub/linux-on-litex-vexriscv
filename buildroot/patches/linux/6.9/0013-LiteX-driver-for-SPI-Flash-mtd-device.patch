+ * Foundation, Inc., 59 Temple Place, Suite 330, Boston, MA  02111-1307  USA
+ */
+
+#include <linux/delay.h>
+#include <linux/err.h>
+#include <linux/io.h>
+#include <linux/iopoll.h>
+#include <linux/module.h>
+#include <linux/mtd/mtd.h>
+#include <linux/mtd/partitions.h>
+#include <linux/mtd/spi-nor.h>
+#include <linux/of.h>
+#include <linux/of_device.h>
+#include <linux/platform_device.h>
+#include <linux/jiffies.h>
+#include <linux/litex.h>
+
+#define LITESPI_PHY_CLK_DIVISOR_OFFSET		0x00
+#define LITESPI_PHY_MODE_OFFSET			0x04
+#define LITESPI_MASTER_CS_OFFSET		0x10
+#define LITESPI_MASTER_PHYCONFIG_OFFSET		0x14
+#define LITESPI_MASTER_RXTX_OFFSET		0x18
+#define LITESPI_MASTER_STATUS_OFFSET		0x1c
+#define LITESPI_MASTER_CLK_DIVISOR_OFFSET	0x20
+
+#define LITESPI_PHYCONFIG_LEN_SHIFT		0
+#define LITESPI_PHYCONFIG_WIDTH_SHIFT		8
+#define LITESPI_PHYCONFIG_MASK_SHIFT		16
+
+#define LITESPI_PHYCONFIG_LEN(n) \
+	((n) << LITESPI_PHYCONFIG_LEN_SHIFT)
+#define LITESPI_PHYCONFIG_WIDTH(n) \
+	((n) << LITESPI_PHYCONFIG_WIDTH_SHIFT)
+#define LITESPI_PHYCONFIG_MASK(n) \
+	((n) << LITESPI_PHYCONFIG_MASK_SHIFT)
+
+#define LITESPI_STATUS_TX_READY			0x01
+#define LITESPI_STATUS_RX_READY			0x02
+#define LITESPI_SINGLE_WIDTH			1
+#define LITESPI_SINGLE_MOSI_MASK		0x01
+#define LITESPI_XFER_BITS			8
+#define LITESPI_DEFAULT_ADDR_WIDTH		3
+#define LITESPI_XFER_TIMEOUT_US			100000
+
+#define WRITE_ENABLE 0x06
+#define READ_STATUS_REGISTER 0x05
+#define WORK_IN_PROGRESS 0x01
+
+#define TIMEOUT_READY_MS 50
+#define TIMEOUT_PROGRAM_MS 1000
+#define TIMEOUT_ERASE_MS 60000
+
+struct litex_spiflash {
+	struct spi_nor nor;
+	struct device *dev;
+	void __iomem *base;
+};
+
+static void litex_spiflash_set_cs(struct litex_spiflash *flash, bool enable)
+{
+	litex_write8(flash->base + LITESPI_MASTER_CS_OFFSET, enable ? 1 : 0);
+}
+
+static void litex_spiflash_init(struct litex_spiflash *flash)
+{
+	u8 clk_divisor;
+	u32 phyconfig;
+
+	clk_divisor = litex_read8(flash->base + LITESPI_PHY_CLK_DIVISOR_OFFSET);
+	phyconfig = LITESPI_PHYCONFIG_LEN(LITESPI_XFER_BITS) |
+		    LITESPI_PHYCONFIG_WIDTH(LITESPI_SINGLE_WIDTH) |
+		    LITESPI_PHYCONFIG_MASK(LITESPI_SINGLE_MOSI_MASK);
+
+	litex_write8(flash->base + LITESPI_PHY_MODE_OFFSET, 0);
+	litex_write32(flash->base + LITESPI_MASTER_PHYCONFIG_OFFSET,
+		      phyconfig);
+	litex_write8(flash->base + LITESPI_MASTER_CLK_DIVISOR_OFFSET,
+		     clk_divisor);
+	litex_spiflash_set_cs(flash, false);
+}
+
+static int litex_spiflash_xfer(struct litex_spiflash *flash, u8 tx, u8 *rx)
+{
+	u8 status;
+	u8 val;
+	int ret;
+
+	ret = read_poll_timeout(litex_read8, status,
+				status & LITESPI_STATUS_TX_READY, 1,
+				LITESPI_XFER_TIMEOUT_US, false,
+				flash->base + LITESPI_MASTER_STATUS_OFFSET);
+	if (ret)
+		return ret;
+
+	litex_write8(flash->base + LITESPI_MASTER_RXTX_OFFSET, tx);
+
+	ret = read_poll_timeout(litex_read8, status,
+				status & LITESPI_STATUS_RX_READY, 1,
+				LITESPI_XFER_TIMEOUT_US, false,
+				flash->base + LITESPI_MASTER_STATUS_OFFSET);
+	if (ret)
+		return ret;
+
+	val = litex_read8(flash->base + LITESPI_MASTER_RXTX_OFFSET);
+	if (rx)
+		*rx = val;
+
+	return 0;
+}
+
+static int litex_spiflash_addr_width(struct spi_nor *nor)
+{
+	return nor->addr_width ? nor->addr_width : LITESPI_DEFAULT_ADDR_WIDTH;
+}
+
+static int litex_spiflash_exec_op(struct spi_nor *nor, u8 opcode,
+				  u64 addr, int addr_width,
+				  const u8 *tx, u8 *rx, size_t len)
+{
+	struct litex_spiflash *flash = nor->priv;
+	size_t i;
+	int shift;
+	int ret;
+
+	litex_spiflash_set_cs(flash, true);
+
+	ret = litex_spiflash_xfer(flash, opcode, NULL);
+	if (ret)
+		goto out;
+
+	for (shift = addr_width - 1; shift >= 0; shift--) {
+		ret = litex_spiflash_xfer(flash, (u8)(addr >> (8 * shift)),
+					  NULL);
+		if (ret)
+			goto out;
+	}
+
+	for (i = 0; i < len; i++) {
+		ret = litex_spiflash_xfer(flash, tx ? tx[i] : 0xff,
+					  rx ? &rx[i] : NULL);
+		if (ret)
+			goto out;
+	}
+
+out:
+	litex_spiflash_set_cs(flash, false);
+	return ret;
+}
+
+static int spi_flash_nor_read_reg(struct spi_nor *nor, u8 opcode, u8 *buf,
+				  size_t len)
+{
+	return litex_spiflash_exec_op(nor, opcode, 0, 0, NULL, buf, len);
+}
+
+static int read_status(struct spi_nor *nor, u8 *status)
+{
+	return spi_flash_nor_read_reg(nor, READ_STATUS_REGISTER, status, 1);
+}
+
+static int wait_until_ready(struct spi_nor *nor, unsigned long timeout_ms)
+{
+	unsigned long end = jiffies + msecs_to_jiffies(timeout_ms);
+	u8 status;
+	int ret;
+
+	do {
+		ret = read_status(nor, &status);
+		if (ret)
+			return ret;
+		if (!(status & WORK_IN_PROGRESS))
+			return 0;
+		usleep_range(1000, 2000);
+	} while (time_before(jiffies, end));
+
+	return -ETIMEDOUT;
+}
+
+static int write_enable(struct spi_nor *nor)
+{
+	return litex_spiflash_exec_op(nor, WRITE_ENABLE, 0, 0, NULL, NULL, 0);
+}
+
+static int spi_flash_nor_erase(struct spi_nor *nor, loff_t offs)
+{
+	int ret;
+
+	ret = wait_until_ready(nor, TIMEOUT_READY_MS);
+	if (ret)
+		return ret;
+
+	ret = write_enable(nor);
+	if (ret)
+		return ret;
+
+	ret = litex_spiflash_exec_op(nor, nor->erase_opcode, offs,
+				     litex_spiflash_addr_width(nor),
+				     NULL, NULL, 0);
+	if (ret)
+		return ret;
+
+	return wait_until_ready(nor, TIMEOUT_ERASE_MS);
+}
+
+static ssize_t spi_flash_nor_read(struct spi_nor *nor, loff_t from,
+				  size_t length, u8 *buffer)
+{
+	int ret;
+
+	ret = wait_until_ready(nor, TIMEOUT_READY_MS);
+	if (ret)
+		return ret;
+
+	ret = litex_spiflash_exec_op(nor, nor->read_opcode, from,
+				     litex_spiflash_addr_width(nor),
+				     NULL, buffer, length);
+	return ret ? ret : length;
+}
+
+static ssize_t spi_flash_nor_write(struct spi_nor *nor, loff_t to,
+				   size_t len, const u8 *buf)
+{
+	int ret;
+
+	ret = wait_until_ready(nor, TIMEOUT_READY_MS);
+	if (ret)
+		return ret;
+
+	ret = write_enable(nor);
+	if (ret)
+		return ret;
+
+	ret = litex_spiflash_exec_op(nor, nor->program_opcode, to,
+				     litex_spiflash_addr_width(nor),
+				     buf, NULL, len);
+	if (ret)
+		return ret;
+
+	ret = wait_until_ready(nor, TIMEOUT_PROGRAM_MS);
+	return ret ? ret : len;
+}
+
+static int spi_flash_nor_write_reg(struct spi_nor *nor, u8 opcode,
+				   const u8 *buf, size_t len)
+{
+	return litex_spiflash_exec_op(nor, opcode, 0, 0, buf, NULL, len);
+}
+
+static const struct spi_nor_controller_ops litex_spi_controller_ops = {
+	.read = spi_flash_nor_read,
+	.write = spi_flash_nor_write,
+	.read_reg = spi_flash_nor_read_reg,
+	.write_reg = spi_flash_nor_write_reg,
+	.erase = spi_flash_nor_erase,
+};
+
+static int litex_spi_flash_probe(struct platform_device *pdev)
+{
+	struct device_node *node;
+	struct resource *res;
+	struct litex_spiflash *flash;
+	int ret;
+	struct spi_nor *nor;
+
+	const struct spi_nor_hwcaps hwcaps = {
+		.mask = SNOR_HWCAPS_READ |
+			SNOR_HWCAPS_PP,
+	};
+
+	if (!pdev->dev.of_node) {
+		dev_err(&pdev->dev, "No DT found\n");
+		return -EINVAL;
+	}
+
+	flash = devm_kzalloc(&pdev->dev, sizeof(*flash), GFP_KERNEL);
+	if (!flash)
+		return -ENOMEM;
+	platform_set_drvdata(pdev, flash);
+
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	flash->base = devm_ioremap_resource(&pdev->dev, res);
+	if (IS_ERR(flash->base))
+		return PTR_ERR(flash->base);
+
+	flash->dev = &pdev->dev;
+
+	/* Gets attached flash */
+	node = of_get_next_available_child(pdev->dev.of_node, NULL);
+	if (!node) {
+		dev_err(&pdev->dev, "no SPI flash device to configure\n");
+		return -ENODEV;
+	}
+	nor = &flash->nor;
+	nor->dev = flash->dev;
+	nor->priv = flash;
+	spi_nor_set_flash_node(nor, node);
+	/* Sets initial configuration of registers */
+	litex_spiflash_init(flash);
+	/* Fill the hooks to spi nor */
+	nor->controller_ops = &litex_spi_controller_ops;
+	nor->mtd.name = "spi";
+
+	ret = spi_nor_scan(nor, NULL, &hwcaps);
+	if (ret) {
+		dev_err(&pdev->dev, "SPI_NOR_SCAN FAILED\n");
+		return ret;
+	}
+
+	ret = mtd_device_register(&nor->mtd, NULL, 0);
+	if (ret) {
+		dev_err(&pdev->dev, "Fail to register device\n");
+		return ret;
+	}
+
+	return 0;
+}
+
+static int litex_spi_flash_remove(struct platform_device *pdev)
+{
+	struct litex_spiflash *flash = platform_get_drvdata(pdev);
+
+	litex_spiflash_set_cs(flash, false);
+	mtd_device_unregister(&flash->nor.mtd);
+
+	return 0;
+}
+
+static const struct of_device_id litex_of_match[] = {
+	{ .compatible = "litex,spiflash" },
+	{}
+};
+
+MODULE_DEVICE_TABLE(of, litex_of_match);
+
+static struct platform_driver litex_spi_flash_driver = {
+	.probe	= litex_spi_flash_probe,
+	.remove	= litex_spi_flash_remove,
+	.driver	= {
+		.name = "litex-spiflash",
+		.of_match_table = of_match_ptr(litex_of_match),
+	},
+};
+module_platform_driver(litex_spi_flash_driver);
+
+MODULE_DESCRIPTION("LiteX SPI Flash driver");
+MODULE_AUTHOR("Antmicro <www.antmicro.com>");
-- 
